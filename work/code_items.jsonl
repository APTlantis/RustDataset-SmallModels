{"id":"code-item-000002","source_path":"src/lib.rs","crate_name":"sample_crate","item_kind":"function","code":"pub fn normalize_name(name: &str) -> String {\n    let trimmed = name.trim();\n    let lowercase = trimmed.to_ascii_lowercase();\n    lowercase.replace(' ', \"_\")\n}","topics":["lib"],"line_count":5,"has_tests":false,"has_main":false}
{"id":"code-item-000003","source_path":"src/lib.rs","crate_name":"sample_crate","item_kind":"function","code":"pub fn sum_even(values: &[i32]) -> i32 {\n    values\n        .iter()\n        .copied()\n        .filter(|value| value % 2 == 0)\n        .sum()\n}","topics":["lib"],"line_count":7,"has_tests":false,"has_main":false}
{"id":"code-item-000004","source_path":"src/main.rs","crate_name":"sample_crate","item_kind":"function","code":"fn main() {\n    let values = vec![1, 2, 3, 4];\n    let total = sample_crate::sum_even(&values);\n    println!(\"{total}\");\n}","topics":["main","vec"],"line_count":5,"has_tests":false,"has_main":true}
